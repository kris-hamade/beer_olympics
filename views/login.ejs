<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
    <link rel="icon" href="/beer_logo_transparent.png" type="image/png" />
  </head>
  <body>
    <main class="page">
      <section class="card">
        <div class="brand-row brand-row-center brand-row-hero">
          <img class="brand-logo brand-logo-hero" src="/beer_logo_transparent.png" alt="Beer Olympics logo" />
        </div>
        <h1>Beer Olympics</h1>
        <p class="subtitle">Private team signup portal. Enter the access password to continue.</p>

        <nav class="page-tabs" aria-label="Quick links">
          <a class="page-tab" href="/admin">Admin</a>
          <a class="page-tab" href="/live-standings" target="_blank" rel="noopener">Live Standings</a>
        </nav>

        <% if (flash && flash.type === "error") { %>
          <div class="alert alert-error"><%= flash.message %></div>
        <% } %>

        <form method="post" action="/login" class="stack">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="field">
            <span>Password</span>
            <input type="password" name="password" required placeholder="Enter password" />
          </label>
          <button type="submit" class="btn">Enter</button>
        </form>
      </section>
    </main>
  </body>
</html>
